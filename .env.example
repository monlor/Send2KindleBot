BOT_TOKEN=123456:telegram-token
BOT_MODE=polling
BOT_ADMIN=0
BOT_DEMO=3
BOT_MULTIPLIER=2
BOT_BLOCKED=
BOT_ALLOWED_USER_IDS=
BOT_DB_PATH=/app/data/db/Send2KindleBot.db
BOT_DB_TABLE=usuarios
BOT_LOG_FILE=/app/data/logs/bot.log
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=bot@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=bot@example.com
SMTP_USE_TLS=1

# Webhook mode only
BOT_WEBHOOK_HOST=
BOT_WEBHOOK_PORT=443
BOT_CERT=/app/certs/fullchain.pem
BOT_PRIVKEY=/app/certs/privkey.pem

# Optional legacy config file path override
BOT_CONFIG_FILE=kindle.conf
